<?xml version="1.0" encoding="UTF-8"?>
<!--
  mobile/ios/NetworkExtension/Info.plist

  PR-25 (Sprint 4) — Info.plist for the NetworkExtension (Packet Tunnel
  Provider) target. Required by iOS as the runtime metadata for the
  `.appex` bundle; `NSExtension.NSExtensionPointIdentifier` MUST be
  `com.apple.networkextension.packet-tunnel` for iOS to dispatch
  `NETunnelProvider` lifecycle callbacks into our
  `OpenE2eeTunnelProvider` class.

  Key entries
  ------------
  - `NSExtension` -> `NSExtensionPointIdentifier` =
    `com.apple.networkextension.packet-tunnel` — Apple's packet-tunnel
    extension point. Without this, iOS will not instantiate the
    `OpenE2eeTunnelProvider` class on `startVPNTunnel()`.
  - `NSExtensionPrincipalClass` = `$(PRODUCT_MODULE_NAME).OpenE2eeTunnelProvider`
    — names the Swift class that iOS should instantiate. The
    `$(PRODUCT_MODULE_NAME)` token is replaced with the NE target's
    product module name (`OpenE2eeTunnelProvider` by default) at build
    time so the FQDN resolves to
    `OpenE2eeTunnelProvider.OpenE2eeTunnelProvider`.
  - `CFBundlePackageType` = `XPC!` — required for app extensions.
  - `MinimumOSVersion` = 14.0 — matches the Runner target. NE per-app
    VPN (`NEAppRules`) is iOS 14+; deny-list (`excludeAppRules`) is
    iOS 15+. Sprint 4 raises to iOS 15+ once the deployment target
    gate is opened.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>OpenE2EE Tunnel</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>MinimumOSVersion</key>
    <string>14.0</string>
    <key>NSExtension</key>
    <dict>
        <key>NSExtensionPointIdentifier</key>
        <string>com.apple.networkextension.packet-tunnel</string>
        <key>NSExtensionPrincipalClass</key>
        <string>$(PRODUCT_MODULE_NAME).OpenE2eeTunnelProvider</string>
    </dict>
</dict>
</plist>